{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                // ${workspaceFolder} = VSCode打开的项目根目录
                // Windows用分号;分隔多路径，Mac/Linux用冒号:
                "PYTHONPATH": "${workspaceFolder};${env:PYTHONPATH}"
            }
        },
        {
            "name": "pytest调试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                // 这里可以指定要运行的测试文件，比如 "tests/common/test_util.py"
                // 也可以留空，运行所有测试
                "-vv",
                "--md=./tests/test_report.md",
                "-s"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
    ]
}